zero_idx <- which(ycol == 0)
if (length(zero_idx) > 0) {
mu_j <- pmax(s[i] * exp(beta[, k]), 1e-300)
p0_vec <- (theta[zero_idx] / (theta[zero_idx] + mu_j[zero_idx]))^theta[zero_idx]
denom_rho <- pmax(pi_mat[zero_idx, k] + (1 - pi_mat[zero_idx, k]) * p0_vec, 1e-300)
rho_vec <- rep(0, G)
rho_vec[zero_idx] <- pi_mat[zero_idx, k] / denom_rho
numer_pi[, k] <- numer_pi[, k] + gammaik * rho_vec
}
}
}
for (k in 1:K) {
Nk_k <- Nk[k]; if (Nk_k < 1e-12) Nk_k <- 1e-12
if (use_beta_prior) {
a <- 1; b <- 1
pi_mat[, k] <- (a + numer_pi[, k]) / (a + b + Nk_k)
} else {
pi_mat[, k] <- numer_pi[, k] / Nk_k
}
}
pi_mat <- clamp(pi_mat, 1e-8, 1 - 1e-8)
if (verbose) message("Beta inner optimization ...")
for (inner in 1:inner_beta_steps) {
for (k in 1:K) {
mu_mat <- outer(exp(beta[, k]), s, "*")
sum_w_j <- numeric(G)
sum_wz_minus_logs <- numeric(G)
for (i in 1:N) {
gammaik <- gamma[i, k]
if (gammaik < 1e-12) next
ycol <- counts[, i]
mu_j <- mu_mat[, i]
zero_idx <- which(ycol == 0)
rho_vec <- numeric(G)
if (length(zero_idx) > 0) {
p0_vec <- (theta[zero_idx] / (theta[zero_idx] + mu_j[zero_idx]))^theta[zero_idx]
denom_rho <- pmax(pi_mat[zero_idx, k] + (1 - pi_mat[zero_idx, k]) * p0_vec, 1e-300)
rho_vec[zero_idx] <- pi_mat[zero_idx, k] / denom_rho
}
w_vec <- gammaik * (1 - rho_vec) * (mu_j / (1 + mu_j / theta))
w_vec[!is.finite(w_vec)] <- 0
z_vec <- logs[i] + beta[, k] + (as.numeric(ycol) - mu_j) / pmax(mu_j, 1e-8)
sum_w_j <- sum_w_j + w_vec
sum_wz_minus_logs <- sum_wz_minus_logs + w_vec * (z_vec - logs[i])
}
T_jk <- as.numeric(W %*% beta[, k])
# 交换惩罚项：lambda1 现在用于图正则化，lambda2 用于 L1 正则化
A_j <- sum_w_j + lambda1 * degW + 1e-12
B_j <- sum_wz_minus_logs + lambda1 * T_jk
bar_b <- B_j / A_j
thresh <- lambda2 / A_j  # L1 正则化使用 lambda2
delta <- bar_b - beta_star
beta[, k] <- beta_star + sign(delta) * pmax(abs(delta) - thresh, 0)
beta[, k] <- pmax(pmin(beta[, k], 20), -20)
}
}
tot_ll <- 0
bad <- FALSE
for (i in 1:N) {
rowlog <- numeric(K)
for (k in 1:K) {
mu_j <- pmax(s[i] * exp(beta[, k]), 1e-300)
ycol <- counts[, i]
lp <- numeric(G)
zero_idx <- which(ycol == 0)
if (length(zero_idx) > 0) {
p0v <- (theta[zero_idx] / (theta[zero_idx] + mu_j[zero_idx]))^theta[zero_idx]
lp[zero_idx] <- log(pmax(pi_mat[zero_idx, k] + (1 - pi_mat[zero_idx, k]) * p0v, 1e-300))
}
pos_idx <- which(ycol > 0)
if (length(pos_idx) > 0) {
ysub <- ycol[pos_idx]; musub <- mu_j[pos_idx]; thetay <- theta[pos_idx]
lp[pos_idx] <- lgamma(ysub + thetay) - lgamma(thetay) - lgamma(ysub + 1) +
thetay * log(thetay) + ysub * log(pmax(musub,1e-300)) - (ysub + thetay) * log(pmax(musub + thetay,1e-300)) +
log(pmax(1 - pi_mat[pos_idx,k], 1e-300))
}
rowlog[k] <- log(pmax(p[k], 1e-12)) + sum(lp)
}
if (all(!is.finite(rowlog))) {
tot_ll <- tot_ll + log(K); bad <- TRUE
} else {
tot_ll <- tot_ll + logsumexp_vec(rowlog)
}
}
loglik_trace[iter] <- tot_ll
if (verbose) message(sprintf("iter %d loglik = %.6f%s", iter, tot_ll, if (bad) " (some bad rows)" else ""))
if (iter > 1) {
diff_ll <- loglik_trace[iter] - loglik_trace[iter - 1]
if (is.na(diff_ll)) {
warning("loglik diff is NA at iter ", iter, " — continuing")
} else if (abs(diff_ll) < tol) {
if (verbose) message("Converged at iter ", iter, " (diff ", diff_ll, ")")
break
}
}
}
labels <- apply(gamma, 1, which.max)
names(labels) <- colnames(counts)
list(beta = beta,
beta_star = beta_star,
pi = pi_mat,
theta = theta,
p = p,
gamma = gamma,
labels = labels,
loglik = loglik_trace[1:iter],
W = W,
genes = rownames(counts))
}
if (verbose) cat("Using all input genes.\n")
res <- fit_zinb_graph_lasso_final(
counts = counts_raw,
K = K,
top_k_graph = top_k_graph,
lambda1 = lambda1,
lambda2 = lambda2,
max_iter = max_iter,
inner_beta_steps = inner_beta_steps,
use_beta_prior = use_beta_prior,
verbose = verbose
)
if (verbose) cat("Done!\n")
return(list(
hvg_genes = rownames(counts_raw),
counts_hvg = counts_raw,
zinb_result = res,
cluster_labels = res$labels
))
}
#读取数据
data<-read.csv("E:/实验数据集/GSE81547_human_data.csv",row.names = 1)
labels<- read.csv("E:/实验数据集/GSE81547_truelabels.csv",row.names = 1)
data_matrix <- as.matrix(data)
labels_matrix <- as.matrix(labels)
#筛选高变基因
select_hvg <- function(counts_raw, nHVG = 1000) {
gene_sums <- rowSums(counts_raw)
keep_genes <- which(gene_sums > 0)
if (length(keep_genes) == 0) stop("All genes are zero.")
counts_filtered <- counts_raw[keep_genes, , drop = FALSE]
gene_means <- rowMeans(counts_filtered)
gene_vars  <- apply(counts_filtered, 1, var)
valid_idx <- which(gene_means > 0 & gene_vars >= 0)
if (length(valid_idx) == 0) stop("No valid genes after filtering.")
df2 <- data.frame(mean = gene_means[valid_idx], var = gene_vars[valid_idx])
if (nrow(df2) < 10) {
hvg_score <- df2$var
} else {
fit <- tryCatch({
loess(log(var) ~ log(mean), data = df2, span = 0.3)
}, error = function(e) {
NULL
})
if (is.null(fit)) {
hvg_score <- df2$var
} else {
hvg_score <- log(df2$var) - predict(fit)
}
}
top_n <- min(nHVG, length(hvg_score))
ranked_idx <- order(hvg_score, decreasing = TRUE)[1:top_n]
rownames(counts_filtered)[valid_idx[ranked_idx]]
}
human_hvg<-select_hvg(data_matrix,nHVG=3000)
new_data <- data_matrix[human_hvg, ]
human_res <- grzinbmm(new_data, K = 6,
top_k_graph = 50, lambda1 = 0.2, lambda2 = 0.1,
max_iter = 10, inner_beta_steps = 10, verbose = TRUE)
dnb_log <- function(x, mu, theta) {
ifelse(x == 0,
theta * log(theta / (theta + mu)),
lgamma(x + theta) - lgamma(theta) - lgamma(x + 1) +
x * log(mu) + theta * log(theta) - (x + theta) * log(mu + theta))
}
grzinbmm <- function(counts_raw,
K = 10,
top_k_graph = 50,
lambda1 = 0.1,
lambda2 = 0.05,
max_iter = 50,
inner_beta_steps = 5,
use_beta_prior = FALSE,
verbose = TRUE) {
logsumexp_vec <- function(x) {
if (!any(is.finite(x))) return(-Inf)
m <- max(x, na.rm = TRUE)
m + log(sum(exp(x - m), na.rm = TRUE))
}
clamp <- function(x, lo, hi) pmax(pmin(x, hi), lo)
log_zinb_gene <- function(y, mu, theta, pi_vec) {
p0 <- (theta / (theta + mu))^theta
out <- numeric(length(y))
is0 <- (y == 0)
out[is0] <- log(clamp(pi_vec[is0] + (1 - pi_vec[is0]) * p0[is0], 1e-300, 1))
pos <- which(!is0)
if (length(pos) > 0) {
ysub <- y[pos]; musub <- mu[pos]
out[pos] <- lgamma(ysub + theta) - lgamma(theta) - lgamma(ysub + 1) +
theta * log(theta) + ysub * log(clamp(musub, 1e-300, Inf)) -
(ysub + theta) * log(clamp(musub + theta, 1e-300, Inf)) +
log(clamp(1 - pi_vec[pos], 1e-300, 1))
}
out
}
build_gene_graph_topK <- function(counts, top_k = 50) {
g <- nrow(counts)
if (g <= 1) return(Matrix(0, nrow = g, ncol = g, sparse = TRUE))
cor_mat <- cor(t(counts), method = "spearman")
diag(cor_mat) <- 0
W <- matrix(0, nrow = g, ncol = g)
for (j in 1:g) {
rv <- cor_mat[j, ]
idx <- head(order(rv, decreasing = TRUE), min(top_k, g - 1))
vals <- rv[idx]
vals[vals < 0] <- 0
W[j, idx] <- vals
}
W <- pmax(W, t(W))
Matrix(W, sparse = TRUE)
}
fit_zinb_graph_lasso_final <- function(counts,
K = 10,
top_k_graph = 50,
lambda1 = 0.1,
lambda2 = 0.1,
max_iter = 100,
tol = 1e-5,
inner_beta_steps = 5,
use_beta_prior = FALSE,
verbose = TRUE) {
G <- nrow(counts)
N <- ncol(counts)
if (verbose) message(sprintf("Running on %d genes × %d cells.", G, N))
s <- colSums(counts)
s[s <= 0] <- 1e-6
logs <- log(s)
theta <- numeric(G)
for (j in 1:G) {
y <- as.numeric(counts[j, ])
m <- mean(y); v <- var(y)
if (v > m + 1e-8) theta[j] <- max(1e-6, m^2 / (v - m)) else theta[j] <- 1e6
}
if (verbose) message("Building gene graph W (Spearman top-K) ...")
W <- build_gene_graph_topK(counts, top_k = top_k_graph)
degW <- as.numeric(rowSums(W))
if (verbose) message("Initializing parameters via PCA + kmeans ...")
lognorm <- log1p(t(t(counts) / s))
pca_k <- min(20, N - 1, nrow(lognorm), ncol(lognorm))
pca <- tryCatch(
irlba(t(lognorm), nv = pca_k),
error = function(e) prcomp(t(lognorm), rank. = pca_k)
)
pcs <- if (is.list(pca) && !is.null(pca$u)) pca$u %*% diag(pca$d) else pca$x
set.seed(123)
km <- kmeans(pcs, centers = K, nstart = 10)
z_init <- km$cluster
gamma <- matrix(1e-12, nrow = N, ncol = K)
for (i in 1:N) gamma[i, z_init[i]] <- 1
gamma <- pmax(gamma, 1e-12)
gamma <- gamma / rowSums(gamma)
p <- colMeans(gamma)
beta <- matrix(0, nrow = G, ncol = K)
for (k in 1:K) {
idxk <- which(z_init == k)
if (length(idxk) > 0) {
mvec <- rowMeans(counts[, idxk, drop = FALSE] / matrix(s[idxk], nrow = G, ncol = length(idxk), byrow = TRUE))
beta[, k] <- log(pmax(mvec, 1e-6))
} else {
beta[, k] <- rnorm(G, 0, 0.1)
}
}
set.seed(123)
beta <- beta + matrix(rnorm(G * K, mean = 0, sd = 0.05), nrow = G, ncol = K)
if (verbose) message("Estimating global beta_star via gene-wise ZINB MLE ...")
beta_star <- numeric(G)
pi_global <- numeric(G)
for (j in 1:G) {
y <- as.numeric(counts[j, ])
if (all(y == 0)) {
beta_star[j] <- -100
pi_global[j] <- 1.0
next
}
neg_loglik <- function(params) {
beta_val <- params[1]
pi_val   <- params[2]
pi_val <- clamp(pi_val, 1e-8, 1 - 1e-8)
mu_vec <- s * exp(beta_val)
ll <- numeric(N)
for (i in 1:N) {
if (y[i] == 0) {
p0 <- (theta[j] / (theta[j] + mu_vec[i]))^theta[j]
ll[i] <- log(pi_val + (1 - pi_val) * p0)
} else {
ll[i] <- log(1 - pi_val) + dnb_log(y[i], mu_vec[i], theta[j])
}
}
-sum(ll)
}
init_beta <- log(mean(y / s))
init_pi   <- mean(y == 0)
init_pi   <- clamp(init_pi, 0.01, 0.99)
opt <- tryCatch({
optim(c(init_beta, init_pi), neg_loglik,
method = "L-BFGS-B",
lower = c(-100, 1e-8),
upper = c(100, 1 - 1e-8),
control = list(maxit = 200))
}, error = function(e) {
list(par = c(init_beta, init_pi), value = Inf)
})
if (is.finite(opt$value)) {
beta_star[j] <- opt$par[1]
pi_global[j] <- clamp(opt$par[2], 1e-8, 1 - 1e-8)
} else {
beta_star[j] <- init_beta
pi_global[j] <- init_pi
if (verbose) warning("MLE failed for gene ", j, "; using initial values.")
}
}
pi_mat <- matrix(0.1, nrow = G, ncol = K)
loglik_trace <- rep(NA_real_, max_iter)
for (iter in 1:max_iter) {
if (verbose) message(sprintf("EM iter %d ...", iter))
loglik_ik <- matrix(NA_real_, nrow = N, ncol = K)
for (k in 1:K) {
mu_j_i <- outer(exp(beta[, k]), s, "*")
sum_logpmf_cells <- rep(0, N)
for (j in 1:G) {
sum_logpmf_cells <- sum_logpmf_cells + log_zinb_gene(as.numeric(counts[j, ]),
mu_j_i[j, ],
theta[j],
rep(pi_mat[j, k], N))
}
loglik_ik[, k] <- log(clamp(p[k], 1e-12, 1)) + sum_logpmf_cells
}
for (i in 1:N) {
lv <- loglik_ik[i, ]
if (all(!is.finite(lv))) {
gamma[i, ] <- rep(1 / K, K)
} else {
m <- max(lv, na.rm = TRUE)
den <- sum(exp(lv - m), na.rm = TRUE)
if (!is.finite(den) || den <= 0) {
gamma[i, ] <- rep(1 / K, K)
} else {
gamma[i, ] <- exp(lv - m) / den
}
}
}
gamma[is.na(gamma)] <- 1e-12
gamma <- pmax(gamma, 1e-12)
gamma <- gamma / rowSums(gamma)
p <- colMeans(gamma)
p <- pmax(p, 1e-12); p <- p / sum(p)
numer_pi <- matrix(0, nrow = G, ncol = K)
Nk <- colSums(gamma)
for (k in 1:K) {
for (i in 1:N) {
gammaik <- gamma[i, k]
if (gammaik < 1e-12) next
ycol <- counts[, i]
zero_idx <- which(ycol == 0)
if (length(zero_idx) > 0) {
mu_j <- pmax(s[i] * exp(beta[, k]), 1e-300)
p0_vec <- (theta[zero_idx] / (theta[zero_idx] + mu_j[zero_idx]))^theta[zero_idx]
denom_rho <- pmax(pi_mat[zero_idx, k] + (1 - pi_mat[zero_idx, k]) * p0_vec, 1e-300)
rho_vec <- rep(0, G)
rho_vec[zero_idx] <- pi_mat[zero_idx, k] / denom_rho
numer_pi[, k] <- numer_pi[, k] + gammaik * rho_vec
}
}
}
for (k in 1:K) {
Nk_k <- Nk[k]; if (Nk_k < 1e-12) Nk_k <- 1e-12
if (use_beta_prior) {
a <- 1; b <- 1
pi_mat[, k] <- (a + numer_pi[, k]) / (a + b + Nk_k)
} else {
pi_mat[, k] <- numer_pi[, k] / Nk_k
}
}
pi_mat <- clamp(pi_mat, 1e-8, 1 - 1e-8)
if (verbose) message("Beta inner optimization ...")
for (inner in 1:inner_beta_steps) {
for (k in 1:K) {
mu_mat <- outer(exp(beta[, k]), s, "*")
sum_w_j <- numeric(G)
sum_wz_minus_logs <- numeric(G)
for (i in 1:N) {
gammaik <- gamma[i, k]
if (gammaik < 1e-12) next
ycol <- counts[, i]
mu_j <- mu_mat[, i]
zero_idx <- which(ycol == 0)
rho_vec <- numeric(G)
if (length(zero_idx) > 0) {
p0_vec <- (theta[zero_idx] / (theta[zero_idx] + mu_j[zero_idx]))^theta[zero_idx]
denom_rho <- pmax(pi_mat[zero_idx, k] + (1 - pi_mat[zero_idx, k]) * p0_vec, 1e-300)
rho_vec[zero_idx] <- pi_mat[zero_idx, k] / denom_rho
}
w_vec <- gammaik * (1 - rho_vec) * (mu_j / (1 + mu_j / theta))
w_vec[!is.finite(w_vec)] <- 0
z_vec <- logs[i] + beta[, k] + (as.numeric(ycol) - mu_j) / pmax(mu_j, 1e-8)
sum_w_j <- sum_w_j + w_vec
sum_wz_minus_logs <- sum_wz_minus_logs + w_vec * (z_vec - logs[i])
}
T_jk <- as.numeric(W %*% beta[, k])
# 交换惩罚项：lambda1 现在用于图正则化，lambda2 用于 L1 正则化
A_j <- sum_w_j + lambda1 * degW + 1e-12
B_j <- sum_wz_minus_logs + lambda1 * T_jk
bar_b <- B_j / A_j
thresh <- lambda2 / A_j
delta <- bar_b - beta_star
beta[, k] <- beta_star + sign(delta) * pmax(abs(delta) - thresh, 0)
beta[, k] <- pmax(pmin(beta[, k], 20), -20)
}
}
tot_ll <- 0
bad <- FALSE
for (i in 1:N) {
rowlog <- numeric(K)
for (k in 1:K) {
mu_j <- pmax(s[i] * exp(beta[, k]), 1e-300)
ycol <- counts[, i]
lp <- numeric(G)
zero_idx <- which(ycol == 0)
if (length(zero_idx) > 0) {
p0v <- (theta[zero_idx] / (theta[zero_idx] + mu_j[zero_idx]))^theta[zero_idx]
lp[zero_idx] <- log(pmax(pi_mat[zero_idx, k] + (1 - pi_mat[zero_idx, k]) * p0v, 1e-300))
}
pos_idx <- which(ycol > 0)
if (length(pos_idx) > 0) {
ysub <- ycol[pos_idx]; musub <- mu_j[pos_idx]; thetay <- theta[pos_idx]
lp[pos_idx] <- lgamma(ysub + thetay) - lgamma(thetay) - lgamma(ysub + 1) +
thetay * log(thetay) + ysub * log(pmax(musub,1e-300)) - (ysub + thetay) * log(pmax(musub + thetay,1e-300)) +
log(pmax(1 - pi_mat[pos_idx,k], 1e-300))
}
rowlog[k] <- log(pmax(p[k], 1e-12)) + sum(lp)
}
if (all(!is.finite(rowlog))) {
tot_ll <- tot_ll + log(K); bad <- TRUE
} else {
tot_ll <- tot_ll + logsumexp_vec(rowlog)
}
}
loglik_trace[iter] <- tot_ll
if (verbose) message(sprintf("iter %d loglik = %.6f%s", iter, tot_ll, if (bad) " (some bad rows)" else ""))
if (iter > 1) {
diff_ll <- loglik_trace[iter] - loglik_trace[iter - 1]
if (is.na(diff_ll)) {
warning("loglik diff is NA at iter ", iter, " — continuing")
} else if (abs(diff_ll) < tol) {
if (verbose) message("Converged at iter ", iter, " (diff ", diff_ll, ")")
break
}
}
}
labels <- apply(gamma, 1, which.max)
names(labels) <- colnames(counts)
list(beta = beta,
beta_star = beta_star,
pi = pi_mat,
theta = theta,
p = p,
gamma = gamma,
labels = labels,
loglik = loglik_trace[1:iter],
W = W,
genes = rownames(counts))
}
if (verbose) cat("Using all input genes.\n")
res <- fit_zinb_graph_lasso_final(
counts = counts_raw,
K = K,
top_k_graph = top_k_graph,
lambda1 = lambda1,
lambda2 = lambda2,
max_iter = max_iter,
inner_beta_steps = inner_beta_steps,
use_beta_prior = use_beta_prior,
verbose = verbose
)
if (verbose) cat("Done!\n")
return(list(
hvg_genes = rownames(counts_raw),
counts_hvg = counts_raw,
zinb_result = res,
cluster_labels = res$labels
))
}
human_res <- grzinbmm(new_data, K = 6,
top_k_graph = 50, lambda1 = 0.2, lambda2 = 0.1,
max_iter = 10, inner_beta_steps = 10, verbose = TRUE)
# 查看输出
table(human_res$cluster_labels)
head(human_res$cluster_labels)
# 计算 ARI（确保对齐后长度一致再计算）
true_labels <- labels_matrix[,4]
pred_labels <- human_res$cluster_labels
pred_cells <- names(pred_labels)
# 对齐真实标签
true_labels_aligned <- labels[pred_cells, "CellType"]
if (length(true_labels_aligned) != length(pred_labels)) {
warning("真实标签与预测标签长度不一致，请检查细胞名对齐。")
} else {
ari <- adjustedRandIndex(true_labels_aligned, pred_labels)
cat("ARI =", ari, "\n")
# 计算NMI
nmi <- NMI(true_labels_aligned, pred_labels)
cat("NMI =", nmi, "\n")
}
